{% doc %}
  @prompt
    Make a carousel with 7 slides - make it so that each slide has an image on the left half. On the right half have a heading and body text. Have the buttons to change slides on the far sides of the carousel.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-container-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-carousel-slides-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    min-width: 100%;
    display: flex;
    align-items: center;
    gap: 0;
  }

  .ai-carousel-image-section-{{ ai_gen_id }} {
    width: 50%;
    flex-shrink: 0;
  }

  .ai-carousel-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.slide_height }}px;
    object-fit: cover;
    display: block;
  }

  .ai-carousel-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.slide_height }}px;
    background-color: #1f1f21;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-carousel-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-carousel-content-section-{{ ai_gen_id }} {
    width: 50%;
    padding: {{ block.settings.content_padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: {{ block.settings.text_color }};
  }

  .ai-carousel-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px 0;
    color: {{ block.settings.heading_color }};
    font-weight: 600;
  }

  .ai-carousel-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    line-height: 1.6;
    margin: 0;
  }

  .ai-carousel-nav-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_color }};
    border: none;
    width: {{ block.settings.button_size }}px;
    height: {{ block.settings.button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background-color 0.3s ease;
  }

  .ai-carousel-nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-carousel-nav-button-{{ ai_gen_id }}--prev {
    left: {{ block.settings.button_offset }}px;
  }

  .ai-carousel-nav-button-{{ ai_gen_id }}--next {
    right: {{ block.settings.button_offset }}px;
  }

  .ai-carousel-nav-button-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    padding: 20px 0;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.4;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: opacity 0.3s ease;
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-slide-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-carousel-image-section-{{ ai_gen_id }},
    .ai-carousel-content-section-{{ ai_gen_id }} {
      width: 100%;
    }

    .ai-carousel-image-{{ ai_gen_id }},
    .ai-carousel-image-placeholder-{{ ai_gen_id }} {
      height: 300px;
    }

    .ai-carousel-content-section-{{ ai_gen_id }} {
      padding: 24px;
    }

    .ai-carousel-nav-button-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-carousel-nav-button-{{ ai_gen_id }}--prev {
      left: 10px;
    }

    .ai-carousel-nav-button-{{ ai_gen_id }}--next {
      right: 10px;
    }
  }
{% endstyle %}

<carousel-block-{{ ai_gen_id }} class="ai-carousel-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-carousel-slides-{{ ai_gen_id }}">
      {% for i in (1..7) %}
        {% liquid
          assign image_key = 'slide_' | append: i | append: '_image'
          assign heading_key = 'slide_' | append: i | append: '_heading'
          assign body_key = 'slide_' | append: i | append: '_body'
          
          assign slide_image = block.settings[image_key]
          assign slide_heading = block.settings[heading_key]
          assign slide_body = block.settings[body_key]
        %}
        
        <div class="ai-carousel-slide-{{ ai_gen_id }}" data-slide="{{ i }}">
          <div class="ai-carousel-image-section-{{ ai_gen_id }}">
            {% if slide_image %}
              <img
                src="{{ slide_image | image_url: width: 1000 }}"
                alt="{{ slide_image.alt | escape }}"
                loading="lazy"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
                class="ai-carousel-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-carousel-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          <div class="ai-carousel-content-section-{{ ai_gen_id }}">
            {% if slide_heading != blank %}
              <h2 class="ai-carousel-heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
            {% endif %}
            {% if slide_body != blank %}
              <div class="ai-carousel-body-{{ ai_gen_id }}">{{ slide_body }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <button
      class="ai-carousel-nav-button-{{ ai_gen_id }} ai-carousel-nav-button-{{ ai_gen_id }}--prev"
      aria-label="Previous slide"
      data-direction="prev"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <button
      class="ai-carousel-nav-button-{{ ai_gen_id }} ai-carousel-nav-button-{{ ai_gen_id }}--next"
      aria-label="Next slide"
      data-direction="next"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>

  <div class="ai-carousel-dots-{{ ai_gen_id }}">
    {% for i in (1..7) %}
      <button
        class="ai-carousel-dot-{{ ai_gen_id }} {% if i == 1 %}active{% endif %}"
        aria-label="Go to slide {{ i }}"
        data-slide="{{ i }}"
      ></button>
    {% endfor %}
  </div>
</carousel-block-{{ ai_gen_id }}>

<script>
  (function() {
    class CarouselBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 1;
        this.totalSlides = 7;
      }

      connectedCallback() {
        this.slidesContainer = this.querySelector('.ai-carousel-slides-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('[data-direction="prev"]');
        this.nextButton = this.querySelector('[data-direction="next"]');
        this.dots = this.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.navigate('prev'));
        this.nextButton.addEventListener('click', () => this.navigate('next'));

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const slideNumber = parseInt(e.target.dataset.slide);
            this.goToSlide(slideNumber);
          });
        });
      }

      navigate(direction) {
        if (direction === 'prev') {
          this.currentSlide = this.currentSlide === 1 ? this.totalSlides : this.currentSlide - 1;
        } else {
          this.currentSlide = this.currentSlide === this.totalSlides ? 1 : this.currentSlide + 1;
        }
        this.updateCarousel();
      }

      goToSlide(slideNumber) {
        this.currentSlide = slideNumber;
        this.updateCarousel();
      }

      updateCarousel() {
        const offset = (this.currentSlide - 1) * -100;
        this.slidesContainer.style.transform = `translateX(${offset}%)`;

        this.dots.forEach((dot, index) => {
          if (index + 1 === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('carousel-block-{{ ai_gen_id }}', CarouselBlock{{ ai_gen_id }});
  })();
</script>

