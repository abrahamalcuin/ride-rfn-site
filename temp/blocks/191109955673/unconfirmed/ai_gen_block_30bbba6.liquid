{% doc %}
  @prompt
    Make a carousel with 7 slides - make it so that each slide has an image on the left half. On the right half have a heading and body text. Have the buttons to change slides on the far sides of the carousel.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-carousel-container-{{ ai_gen_id }} {
    display: block;
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
  }

  .ai-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .ai-carousel-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.5s ease-in-out;
  }

  .ai-carousel-slide-{{ ai_gen_id }} {
    min-width: 100%;
    display: flex;
    align-items: center;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-carousel-image-container-{{ ai_gen_id }} {
    flex: 0 0 50%;
    width: 50%;
  }

  .ai-carousel-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-carousel-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-carousel-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-carousel-content-{{ ai_gen_id }} {
    flex: 0 0 50%;
    width: 50%;
    padding: {{ block.settings.content_padding }}px;
  }

  .ai-carousel-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin }}px 0;
    font-weight: 600;
  }

  .ai-carousel-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  .ai-carousel-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_color }};
    border: none;
    width: {{ block.settings.button_size }}px;
    height: {{ block.settings.button_size }}px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background-color 0.3s ease;
  }

  .ai-carousel-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-carousel-button-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
  }

  .ai-carousel-button-prev-{{ ai_gen_id }} {
    left: {{ block.settings.button_offset }}px;
  }

  .ai-carousel-button-next-{{ ai_gen_id }} {
    right: {{ block.settings.button_offset }}px;
  }

  .ai-carousel-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: {{ block.settings.dots_margin_top }}px;
  }

  .ai-carousel-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-carousel-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-carousel-slide-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-carousel-image-container-{{ ai_gen_id }},
    .ai-carousel-content-{{ ai_gen_id }} {
      flex: 0 0 100%;
      width: 100%;
    }

    .ai-carousel-button-{{ ai_gen_id }} {
      width: {{ block.settings.button_size | times: 0.8 }}px;
      height: {{ block.settings.button_size | times: 0.8 }}px;
    }

    .ai-carousel-button-prev-{{ ai_gen_id }} {
      left: {{ block.settings.button_offset | times: 0.5 }}px;
    }

    .ai-carousel-button-next-{{ ai_gen_id }} {
      right: {{ block.settings.button_offset | times: 0.5 }}px;
    }
  }
{% endstyle %}

<carousel-component-{{ ai_gen_id }} class="ai-carousel-container-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-carousel-track-{{ ai_gen_id }}">
      {% for i in (1..7) %}
        {% liquid
          assign image_key = 'slide_' | append: i | append: '_image'
          assign heading_key = 'slide_' | append: i | append: '_heading'
          assign text_key = 'slide_' | append: i | append: '_text'
          
          assign slide_image = block.settings[image_key]
          assign slide_heading = block.settings[heading_key]
          assign slide_text = block.settings[text_key]
        %}
        
        <div class="ai-carousel-slide-{{ ai_gen_id }}" data-slide="{{ forloop.index0 }}">
          <div class="ai-carousel-image-container-{{ ai_gen_id }}">
            {% if slide_image %}
              <img
                src="{{ slide_image | image_url: width: 1000 }}"
                alt="{{ slide_image.alt | escape }}"
                loading="lazy"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
                class="ai-carousel-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-carousel-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          <div class="ai-carousel-content-{{ ai_gen_id }}">
            {% if slide_heading != blank %}
              <h3 class="ai-carousel-heading-{{ ai_gen_id }}">{{ slide_heading }}</h3>
            {% endif %}
            
            {% if slide_text != blank %}
              <div class="ai-carousel-text-{{ ai_gen_id }}">{{ slide_text }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    
    <button
      class="ai-carousel-button-{{ ai_gen_id }} ai-carousel-button-prev-{{ ai_gen_id }}"
      aria-label="Previous slide"
      data-direction="prev"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>
    
    <button
      class="ai-carousel-button-{{ ai_gen_id }} ai-carousel-button-next-{{ ai_gen_id }}"
      aria-label="Next slide"
      data-direction="next"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
  
  <div class="ai-carousel-dots-{{ ai_gen_id }}">
    {% for i in (1..7) %}
      <button
        class="ai-carousel-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
        aria-label="Go to slide {{ i }}"
        data-slide="{{ forloop.index0 }}"
      ></button>
    {% endfor %}
  </div>
</carousel-component-{{ ai_gen_id }}>

<script>
  (function() {
    class CarouselComponent{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.totalSlides = 7;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-carousel-track-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-carousel-button-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-carousel-button-next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-carousel-dot-{{ ai_gen_id }}');
        
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.navigate('prev'));
        this.nextButton.addEventListener('click', () => this.navigate('next'));
        
        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const slideIndex = parseInt(e.target.dataset.slide);
            this.goToSlide(slideIndex);
          });
        });
      }

      navigate(direction) {
        if (direction === 'prev') {
          this.currentSlide = this.currentSlide === 0 ? this.totalSlides - 1 : this.currentSlide - 1;
        } else {
          this.currentSlide = this.currentSlide === this.totalSlides - 1 ? 0 : this.currentSlide + 1;
        }
        this.updateCarousel();
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateCarousel();
      }

      updateCarousel() {
        const offset = -this.currentSlide * 100;
        this.track.style.transform = `translateX(${offset}%)`;
        
        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }

    customElements.define('carousel-component-{{ ai_gen_id }}', CarouselComponent{{ ai_gen_id }});
  })();
</script>

