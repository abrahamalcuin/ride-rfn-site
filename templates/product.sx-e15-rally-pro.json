    "collapsible_content_GkYAc7": {
      "type": "collapsible-content",
      "blocks": {
        "collapsible_row_dabaKM": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Specifications",
            "icon": "none",
            "row_content": "<p><strong>Performance</strong></p><ul><li>Top Speed: <strong>61 MPH</strong></li><li>Range: <strong>Up to 50 miles</strong></li><li>Power Modes: <strong>5</strong></li><li>Reverse: <strong>Yes</strong></li><li>Peak Power: <strong>15 kW</strong></li></ul><p><strong>Powertrain</strong></p><ul><li>Battery: <strong>74V Samsung 40Ah</strong></li><li>Regenerative Braking: <strong>Yes</strong></li><li>No oil changes</li><li>No top-end rebuilds</li><li>No fuel mixing</li></ul><p><strong>Chassis & Suspension</strong></p><ul><li>Frame: <strong>Chromoly race frame</strong></li><li>Front Suspension: <strong>Fully adjustable race suspension</strong></li><li>Rear Suspension: <strong>Fully adjustable race suspension</strong></li><li>Wheels: <strong>21” front / 18” rear (full-size)</strong></li><li>Brakes: <strong>Double-piston moto brakes</strong></li></ul><p><strong>Ergonomics & Weight</strong></p><ul><li>Seat Height: <strong>36.2”</strong></li><li>Weight (Ready-to-Ride): <strong>205 lbs</strong></li></ul><p><strong>Other</strong></p><ul><li>Real moto geometry & capability</li><li>Track or trail ready</li><li>Minimal maintenance</li><li>Designed for true dirt bike performance</li></ul>",
            "page": ""
          }
        },
        "collapsible_row_d6J9qR": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Premium Samsung Battery",
            "icon": "none",
            "row_content": "<p>The 74V 40Ah battery is built for long lifespan and reliability. Ride farther, swap in under 90 seconds, and keep charging off your mind.</p>",
            "page": ""
          }
        },
        "collapsible_row_UKa3fj": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Seat Height / Rider Size",
            "icon": "none",
            "row_content": "<p>34.6\" seat height, balanced geometry, and 19\"/16\" wheels deliver confidence and comfort for riders 5'4\" and taller.</p>",
            "page": ""
          }
        },
        "collapsible_row_HViWFY": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Trail to Track Versatility ",
            "icon": "none",
            "row_content": "<p>With advanced geometry, capable hydraulic front and rear disk brakes, and top of the line tires, the SX-E15 conquers both technical trails or going for a win on the track.</p>",
            "page": ""
          }
        },
        "collapsible_row_P6iHNn": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Wheels / Tires",
            "icon": "none",
            "row_content": "<p>19\" Front / 16\" Rear</p><p>Ultra-grip tires</p>",
            "page": ""
          }
        },
        "collapsible_row_adkKYz": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Fully Adjustable Suspension",
            "icon": "none",
            "row_content": "<p>Fully adjustable suspension allows riders to adjust the dampness and rebound of both the front and rear suspension, allowing for complete customization for terrain.</p>",
            "page": ""
          }
        },
        "collapsible_row_hcEzqP": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Brakes",
            "icon": "none",
            "row_content": "<p>Powerful front & rear hydraulic disk brakes give consistent power down long, steep technical descents.</p>",
            "page": ""
          }
        },
        "collapsible_row_JPWijd": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Regenerative Braking ",
            "icon": "none",
            "row_content": "<p>Extends range significantly by recharging the battery while decelerating or coasting down hill. Completely adjustable through the RFN App.</p>",
            "page": ""
          }
        },
        "collapsible_row_QCbybU": {
          "type": "collapsible_row",
          "settings": {
            "heading": "RFN App",
            "icon": "none",
            "row_content": "<p>See stats, control top speeds, adjust torque and more all settings from your phone.</p>",
            "page": ""
          }
        },
        "collapsible_row_BE4iJQ": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Warranty",
            "icon": "none",
            "row_content": "<p>Comprehensive warranty protects customers from defective parts.</p><p>Battery - 24 months</p><p>Motor - 24 months</p><p>Controller - 24 months</p><p>Charger - 24 months</p><p>F/R wheel without tire - 10000km</p><p>Front suspension fork - 6 months or 3000km</p><p>Rear shock - 6 months or 3000km</p><p>Display - 12 months</p><p>Chain - 1500km</p><p>Sprocket - 5000km</p><p>Saddle - 12 months</p><p>Harness - 12 months</p><p>Disc rotor - Lifetime</p><p>Speed mode button - 12 months</p><p>Emergency power off switch - 12 months</p><p>Front brake assembly (without brake pads) - 12 months</p><p>Rear brake assembly (without brake pads) - 12 months</p><p> </p>",
            "page": ""
          }
        },
        "collapsible_row_yaxRwF": {
          "type": "collapsible_row",
          "settings": {
            "heading": "Return Policy",
            "icon": "none",
            "row_content": "<p>Unopened items in original packaging can be returned 30 days after the product is received. </p>",
            "page": ""
          }
        }
      },
